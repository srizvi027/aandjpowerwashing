{
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "functions": {
    "api/[[...route]].js": {
      "maxDuration": 30,
      "includeFiles": "dist/**/*"
    }
  },
  "rewrites": [
    {
      "source": "/assets/(.*)",
      "destination": "/dist/client/assets/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/api/[[...route]].js"
    }
  ]
}
