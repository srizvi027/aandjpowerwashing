{
  "buildCommand": "npm run build",
  "functions": {
    "api/[[...route]].js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/assets/(.*)",
      "destination": "/dist/client/assets/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/api/[[...route]].js"
    }
  ]
}
